# ============================================================
# MemEval — Backboard.io
# Usage: ./scripts/run_locomo_eval.sh --lib backboard --env .env.backboard
# Docs: https://docs.backboard.io/
# ============================================================

# ─── Backboard API ───────────────────────────────────────────
BACKBOARD_API_KEY="<YOUR_BACKBOARD_API_KEY>"       # ⚠️ REQUIRED
BACKBOARD_BASE_URL="https://app.backboard.io/api"
BACKBOARD_QPS=5
BACKBOARD_BATCH_SIZE=20
BACKBOARD_HTTP_TIMEOUT=180

# Built-in LLM (used for reflect mode answers)
BACKBOARD_LLM_PROVIDER=openai
BACKBOARD_LLM_MODEL_NAME=gpt-4.1-mini

# Memory mode:
#   lite — Memory Lite, memory="Auto" (official benchmark mode)
#   pro  — Memory Pro, memory_pro="Auto" (higher precision extraction, higher cost)
BACKBOARD_MEMORY_MODE=lite

# Ingestion parameters
# Skip LLM response generation (store messages + trigger memory extraction only)
BACKBOARD_SEND_TO_LLM="false"
# Poll memory_operation_id until extraction completes (recommended)
BACKBOARD_WAIT_FOR_MEMORY="true"
# Operation poll timeout (seconds)
BACKBOARD_MEMORY_TIMEOUT=300
# Poll interval (seconds)
BACKBOARD_MEMORY_POLL_INTERVAL=2
# Ingest mode:
#   per_turn — send messages one by one (official benchmark, more precise extraction)
#   batch    — merge entire session into one message (faster but lower quality)
BACKBOARD_INGEST_MODE=per_turn

# Runner defaults
LLM_WORKERS=10

# Search parameters
TOPK=20
# Search mode:
#   api     — POST /memories/search (basic semantic search, fast, low cost)
#   message — send via memory="Readonly" to trigger retrieval pipeline (higher precision)
BACKBOARD_SEARCH_MODE=message

# Eval mode:
#   rag     — retrieve memory → feed to external ANSWER_MODEL (standard RAG)
#   reflect — Backboard built-in LLM answers directly (memory="auto", send_to_llm=true)
#             Official benchmark uses this mode
BACKBOARD_EVAL_MODE=reflect

# Advanced assistant configuration (optional)
# BACKBOARD_CUSTOM_FACT_EXTRACTION_PROMPT=
# BACKBOARD_CUSTOM_UPDATE_MEMORY_PROMPT=

# ─── ANSWER (Answer Generation, rag mode only) ──────────────
ANSWER_MODEL="gpt-4.1-mini"
ANSWER_BASE_URL="https://api.openai.com/v1"        # ⚠️ REQUIRED — set your LLM endpoint
ANSWER_API_KEY="<YOUR_ANSWER_API_KEY>"             # ⚠️ REQUIRED

# ─── EVAL (LLM-as-Judge Scoring) ────────────────────────────
EVAL_MODEL="gpt-4o-mini"
EVAL_BASE_URL="https://api.openai.com/v1"          # ⚠️ REQUIRED — set your LLM endpoint
EVAL_API_KEY="<YOUR_EVAL_API_KEY>"                 # ⚠️ REQUIRED

# ─── Optional Shared Controls ───────────────────────────────
# Memory API retry controls. HTTP retry count includes the initial attempt.
# MEMEVAL_MEMORY_MAX_RETRIES=8
# MEMEVAL_MEMORY_SDK_MAX_RETRIES=8

# Long add-call progress logging. Set to 0 to disable periodic heartbeat logs.
# MEMEVAL_ADD_HEARTBEAT_SECONDS=30

# Global LLM retry/timeout controls. ANSWER_* and EVAL_* override LLM_*.
# LLM_MAX_RETRIES=4
# LLM_TIMEOUT_SECONDS=600
# LLM_RETRY_BASE_SECONDS=1
# LLM_RETRY_MAX_SECONDS=60
# ANSWER_MAX_RETRIES=4
# ANSWER_TIMEOUT_SECONDS=600
# ANSWER_RETRY_BASE_SECONDS=1
# ANSWER_RETRY_MAX_SECONDS=60
# EVAL_MAX_RETRIES=4
# EVAL_TIMEOUT_SECONDS=600
# EVAL_RETRY_BASE_SECONDS=1
# EVAL_RETRY_MAX_SECONDS=60

# Optional metric resource download/cache overrides.
# HF_ENDPOINT="https://huggingface.co"
# HF_HOME="~/.cache/huggingface"
# MEMEVAL_NLTK_INDEX_URL=
# MEMEVAL_NLTK_GITHUB_PROXY=

# Optional global add batching fallback; product-specific *_MAX_BATCH_CHARS wins.
# MAX_BATCH_CHARS=0

# ─── Notification (Optional) ────────────────────────────────
# DINGTALK_ACCESS_TOKEN="<YOUR_DINGTALK_ACCESS_TOKEN>"
# DINGTALK_SECRET="<YOUR_DINGTALK_SECRET>"

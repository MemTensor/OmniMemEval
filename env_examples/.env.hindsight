# ============================================================
# MemEval — Hindsight (Vectorize)
# Usage: ./scripts/run_locomo_eval.sh --lib hindsight --env .env.hindsight
# Docs: https://docs.hindsight.vectorize.io/
# ============================================================

# ─── Hindsight API ───────────────────────────────────────────
HINDSIGHT_API_KEY="<YOUR_HINDSIGHT_API_KEY>"       # ⚠️ REQUIRED
HINDSIGHT_BASE_URL="https://api.hindsight.vectorize.io"
HINDSIGHT_QPS=5

# Evaluation mode:
#   recall  — Recall API retrieves memories → external LLM generates answer (recommended)
#   reflect — Reflect API generates answer directly (Hindsight built-in reasoning)
HINDSIGHT_MODE=recall

# ─── Retain (memory storage) ────────────────────────────────
# extraction_mode: concise (server default) / verbose (more detail, higher cost) / custom
# HINDSIGHT_RETAIN_EXTRACTION_MODE=verbose
# retain_mission: guide extraction LLM (leave empty for official built-in rules)
# HINDSIGHT_RETAIN_MISSION=
# observations_mission: guide knowledge synthesis (leave empty for built-in rules)
# HINDSIGHT_OBSERVATIONS_MISSION=
# async: true = return immediately, extract in background; false = wait for extraction
HINDSIGHT_RETAIN_ASYNC=true
HINDSIGHT_BATCH_SIZE=20
HINDSIGHT_MAX_BATCH_CHARS=40000
HINDSIGHT_RETAIN_BATCH_SIZE=20

# ─── Recall (memory retrieval) ──────────────────────────────
# Runner defaults
LLM_WORKERS=10

# Search parameters
# Hindsight recall mainly uses token budgets; TOPK is still recorded as the shared runner setting.
TOPK=20
# budget: low (fast) / mid (balanced, default) / high (deep exploration, finds indirect associations)
HINDSIGHT_RECALL_BUDGET=high
# max_tokens: total token budget for returned facts (default 32768)
HINDSIGHT_RECALL_MAX_TOKENS=32768
# include_chunks: return raw text chunks for full conversation context
HINDSIGHT_RECALL_INCLUDE_CHUNKS=true
# max_chunk_tokens: token budget for raw text chunks (default 16384)
HINDSIGHT_RECALL_MAX_CHUNK_TOKENS=16384

# ─── Reflect (AI-generated answers) ─────────────────────────
# budget: low (fast, default) / mid (multi-source) / high (deep, multi-variant queries)
HINDSIGHT_REFLECT_BUDGET=high
# max_tokens: max tokens for generated answer
HINDSIGHT_REFLECT_MAX_TOKENS=4096
# include_facts: return referenced memory sources (true/false)
HINDSIGHT_REFLECT_INCLUDE_FACTS=true

# ─── ANSWER (Answer Generation) ─────────────────────────────
ANSWER_MODEL="gpt-4.1-mini"
ANSWER_BASE_URL="https://api.openai.com/v1"        # ⚠️ REQUIRED — set your LLM endpoint
ANSWER_API_KEY="<YOUR_ANSWER_API_KEY>"             # ⚠️ REQUIRED

# ─── EVAL (LLM-as-Judge Scoring) ────────────────────────────
EVAL_MODEL="gpt-4o-mini"
EVAL_BASE_URL="https://api.openai.com/v1"          # ⚠️ REQUIRED — set your LLM endpoint
EVAL_API_KEY="<YOUR_EVAL_API_KEY>"                 # ⚠️ REQUIRED

# ─── Optional Shared Controls ───────────────────────────────
# Memory API retry controls. HTTP retry count includes the initial attempt.
# MEMEVAL_MEMORY_MAX_RETRIES=8
# MEMEVAL_MEMORY_SDK_MAX_RETRIES=8

# Long add-call progress logging. Set to 0 to disable periodic heartbeat logs.
# MEMEVAL_ADD_HEARTBEAT_SECONDS=30

# Global LLM retry/timeout controls. ANSWER_* and EVAL_* override LLM_*.
# LLM_MAX_RETRIES=4
# LLM_TIMEOUT_SECONDS=600
# LLM_RETRY_BASE_SECONDS=1
# LLM_RETRY_MAX_SECONDS=60
# ANSWER_MAX_RETRIES=4
# ANSWER_TIMEOUT_SECONDS=600
# ANSWER_RETRY_BASE_SECONDS=1
# ANSWER_RETRY_MAX_SECONDS=60
# EVAL_MAX_RETRIES=4
# EVAL_TIMEOUT_SECONDS=600
# EVAL_RETRY_BASE_SECONDS=1
# EVAL_RETRY_MAX_SECONDS=60

# Optional metric resource download/cache overrides.
# HF_ENDPOINT="https://huggingface.co"
# HF_HOME="~/.cache/huggingface"
# MEMEVAL_NLTK_INDEX_URL=
# MEMEVAL_NLTK_GITHUB_PROXY=

# Optional global add batching fallback; product-specific *_MAX_BATCH_CHARS wins.
# MAX_BATCH_CHARS=0

# ─── Notification (Optional) ────────────────────────────────
# DINGTALK_ACCESS_TOKEN="<YOUR_DINGTALK_ACCESS_TOKEN>"
# DINGTALK_SECRET="<YOUR_DINGTALK_SECRET>"

# ============================================================
# OmniMemEval — Cognee
# Usage: ./scripts/run_locomo_eval.sh --lib cognee --env .env.cognee
# Docs: https://docs.cognee.ai/api-reference/introduction
# ============================================================

# ─── Cognee API ──────────────────────────────────────────────
# Cloud auth: X-Api-Key header. Self-hosted with login: use COGNEE_BEARER_TOKEN instead.
COGNEE_API_KEY="<YOUR_COGNEE_API_KEY>"             # Required for cloud
COGNEE_BASE_URL="https://api.cognee.ai"            # Cloud default; set self-hosted endpoint when needed
# Local example: COGNEE_BASE_URL="http://127.0.0.1:8001"
# COGNEE_BEARER_TOKEN=""                           # Required for auth-enabled self-hosted deployments
COGNEE_QPS=5
COGNEE_BATCH_SIZE=20
COGNEE_TIMEOUT=600

# Ingestion (remember) parameters
# Run cognify synchronously to ensure data is ready before search
COGNEE_REMEMBER_RUN_IN_BACKGROUND="false"
# COGNEE_REMEMBER_CUSTOM_PROMPT=""
# COGNEE_REMEMBER_CHUNKS_PER_BATCH=10
# COGNEE_REMEMBER_NODE_SET=""

# Runner defaults
LLM_WORKERS=10

# Search parameters
TOPK=20
# SearchType options:
#   Graph+LLM (recommended):  GRAPH_COMPLETION, GRAPH_COMPLETION_COT,
#                              GRAPH_COMPLETION_CONTEXT_EXTENSION, GRAPH_SUMMARY_COMPLETION
#   RAG+LLM:                  RAG_COMPLETION, TRIPLET_COMPLETION
#   Retrieval only (no LLM):  CHUNKS, CHUNKS_LEXICAL, SUMMARIES
#   Time-aware:                TEMPORAL
#   Auto-select:               FEELING_LUCKY
COGNEE_SEARCH_TYPE="GRAPH_COMPLETION"
# "search" endpoint supports precise strategy control; "recall" endpoint auto-routes
COGNEE_SEARCH_ENDPOINT="search"
# For completion types: true = skip Cognee LLM, return graph context only (use ANSWER_MODEL)
#                       false = Cognee LLM generates answer directly (skip ANSWER_MODEL)
COGNEE_ONLY_CONTEXT="true"
# COGNEE_SYSTEM_PROMPT=""
# COGNEE_VERBOSE="false"

# Cleanup/delete parameters
COGNEE_DELETE_RETRIES=3
COGNEE_FORGET_RETRIES=2
COGNEE_DELETE_TIMEOUT=600
COGNEE_DELETE_VERIFY_RETRIES=3
COGNEE_DELETE_VERIFY_DELAY=1

# Local/self-hosted note: run with --workers 1 if the service is resource constrained.

# ─── ANSWER (Answer Generation) ─────────────────────────────
ANSWER_MODEL="gpt-4.1-mini"
ANSWER_BASE_URL="https://api.openai.com/v1"        # ⚠️ REQUIRED — set your LLM endpoint
ANSWER_API_KEY="<YOUR_ANSWER_API_KEY>"             # ⚠️ REQUIRED

# ─── EVAL (LLM-as-Judge Scoring) ────────────────────────────
EVAL_MODEL="gpt-4o-mini"
EVAL_BASE_URL="https://api.openai.com/v1"          # ⚠️ REQUIRED — set your LLM endpoint
EVAL_API_KEY="<YOUR_EVAL_API_KEY>"                 # ⚠️ REQUIRED

# ─── Optional Shared Controls ───────────────────────────────
# Memory API retry controls. HTTP retry count includes the initial attempt.
# OMNIMEMEVAL_MEMORY_MAX_RETRIES=8
# OMNIMEMEVAL_MEMORY_SDK_MAX_RETRIES=8

# Long add-call progress logging. Set to 0 to disable periodic heartbeat logs.
# OMNIMEMEVAL_ADD_HEARTBEAT_SECONDS=30

# Global LLM retry/timeout controls. ANSWER_* and EVAL_* override LLM_*.
# LLM_MAX_RETRIES=4
# LLM_TIMEOUT_SECONDS=600
# LLM_RETRY_BASE_SECONDS=1
# LLM_RETRY_MAX_SECONDS=60
# ANSWER_MAX_RETRIES=4
# ANSWER_TIMEOUT_SECONDS=600
# ANSWER_RETRY_BASE_SECONDS=1
# ANSWER_RETRY_MAX_SECONDS=60
# EVAL_MAX_RETRIES=4
# EVAL_TIMEOUT_SECONDS=600
# EVAL_RETRY_BASE_SECONDS=1
# EVAL_RETRY_MAX_SECONDS=60

# Optional metric resource download/cache overrides.
# HF_ENDPOINT="https://huggingface.co"
# HF_HOME="~/.cache/huggingface"
# OMNIMEMEVAL_NLTK_INDEX_URL=
# OMNIMEMEVAL_NLTK_GITHUB_PROXY=

# Optional global add batching fallback; product-specific *_MAX_BATCH_CHARS wins.
# MAX_BATCH_CHARS=0

# ─── Notification (Optional) ────────────────────────────────
# DINGTALK_ACCESS_TOKEN="<YOUR_DINGTALK_ACCESS_TOKEN>"
# DINGTALK_SECRET="<YOUR_DINGTALK_SECRET>"

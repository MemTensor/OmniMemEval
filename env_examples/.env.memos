# ============================================================
# MemEval — MemOS (memos)
# Usage: ./scripts/run_locomo_eval.sh --lib memos --env .env.memos
# ============================================================

# ─── MemOS API ───────────────────────────────────────────────
# cloud: hosted OpenMem API; local: self-hosted MemOS /product API.
MEMOS_MODE="cloud"
MEMOS_API_KEY="<YOUR_MEMOS_API_KEY>"              # ⚠️ REQUIRED in cloud mode; optional in local mode
# MEMOS_BASE_URL="https://memos.memtensor.cn/api/openmem/v1"
# MEMOS_BASE_URL="http://localhost:8000"          # local default
MEMOS_BATCH_SIZE=20
MEMOS_MAX_BATCH_CHARS=40000
MEMOS_TIMEOUT=300
# Optional client-side QPS limiter. 0/unset means no local throttle.
MEMOS_QPS=0

# Add parameters
# cloud accepts boolean-style values; local accepts sync|async. Prefer sync for
# local evaluations unless you add an explicit wait/readiness step.
MEMOS_ASYNC_MODE="true"
# Local-only add mode override, used when MEMOS_MODE=local.
#MEMOS_LOCAL_ADD_MODE=""
# user: one mem cube per benchmark user; constant: shared fixed mem cube.
MEMOS_LOCAL_MEM_CUBE_ID_MODE="user"
MEMOS_LOCAL_MEM_CUBE_ID="memeval"

# Runner defaults
LLM_WORKERS=10

# Search parameters
# Ref: https://memos-docs.openmem.net/cn/api_docs/core/search_memory
TOPK=20
MEMOS_INCLUDE_PREFERENCE="true"
MEMOS_PREFERENCE_LIMIT="9"
MEMOS_RELATIVITY="0"
# Cloud and local search context format when supported by the target service.
MEMOS_CONTEXT_FORMAT="memory"
# Enable when a run should retrieve MemOS tool memories.
MEMOS_SEARCH_TOOL_MEMORY="false"
MEMOS_TOOL_MEMORY_LIMIT=20
MEMOS_SEARCH_MODE="fast"
# Optional search deduplication flag passed through to MemOS when supported.
#MEMOS_DEDUP=""

# ─── ANSWER (Answer Generation) ─────────────────────────────
ANSWER_MODEL="gpt-4.1-mini"
ANSWER_BASE_URL="https://api.openai.com/v1"       # ⚠️ REQUIRED — set your LLM endpoint
ANSWER_API_KEY="<YOUR_ANSWER_API_KEY>"             # ⚠️ REQUIRED

# ─── EVAL (LLM-as-Judge Scoring) ────────────────────────────
EVAL_MODEL="gpt-4o-mini"
EVAL_BASE_URL="https://api.openai.com/v1"          # ⚠️ REQUIRED — set your LLM endpoint
EVAL_API_KEY="<YOUR_EVAL_API_KEY>"                 # ⚠️ REQUIRED

# ─── Optional Shared Controls ───────────────────────────────
# Memory API retry controls. HTTP retry count includes the initial attempt.
# MEMEVAL_MEMORY_MAX_RETRIES=8
# MEMEVAL_MEMORY_SDK_MAX_RETRIES=8

# Long add-call progress logging. Set to 0 to disable periodic heartbeat logs.
# MEMEVAL_ADD_HEARTBEAT_SECONDS=30

# Global LLM retry/timeout controls. ANSWER_* and EVAL_* override LLM_*.
# LLM_MAX_RETRIES=4
# LLM_TIMEOUT_SECONDS=600
# LLM_RETRY_BASE_SECONDS=1
# LLM_RETRY_MAX_SECONDS=60
# ANSWER_MAX_RETRIES=4
# ANSWER_TIMEOUT_SECONDS=600
# ANSWER_RETRY_BASE_SECONDS=1
# ANSWER_RETRY_MAX_SECONDS=60
# EVAL_MAX_RETRIES=4
# EVAL_TIMEOUT_SECONDS=600
# EVAL_RETRY_BASE_SECONDS=1
# EVAL_RETRY_MAX_SECONDS=60

# Optional metric resource download/cache overrides.
# HF_ENDPOINT="https://huggingface.co"
# HF_HOME="~/.cache/huggingface"
# MEMEVAL_NLTK_INDEX_URL=
# MEMEVAL_NLTK_GITHUB_PROXY=

# Optional global add batching fallback; product-specific *_MAX_BATCH_CHARS wins.
# MAX_BATCH_CHARS=0

# ─── Notification (Optional) ────────────────────────────────
# DINGTALK_ACCESS_TOKEN="<YOUR_DINGTALK_ACCESS_TOKEN>"
# DINGTALK_SECRET="<YOUR_DINGTALK_SECRET>"

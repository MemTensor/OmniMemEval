# ============================================================
# MemEval — MemoryLake (Powerdrill, V2 API)
# Usage: ./scripts/run_locomo_eval.sh --lib memorylake --env .env.memorylake
# Docs: https://docs.memorylake.ai/features/memorylake/api-reference/overview
# ============================================================

# ─── MemoryLake API ──────────────────────────────────────────
MEMORYLAKE_API_KEY="<YOUR_MEMORYLAKE_API_KEY>"     # ⚠️ REQUIRED
MEMORYLAKE_BASE_URL="https://app.memorylake.ai/openapi/memorylake"
MEMORYLAKE_BATCH_SIZE=20
MEMORYLAKE_MAX_BATCH_CHARS=40000
MEMORYLAKE_DELETE_MAX_PASSES=20

# Project configuration (MemoryLake uses Project as top-level data isolation unit)
# Set an existing project ID, or leave unset to auto-create/find by project name.
# MEMORYLAKE_PROJECT_ID="<YOUR_PROJECT_ID>"
MEMORYLAKE_PROJECT_NAME="memeval"

# Add parameters
# MEMORYLAKE_INFER="true"                          # LLM-inferred structured memory extraction (default: true; false = raw storage)

# Runner defaults
LLM_WORKERS=10

# Search parameters
TOPK=20
# MEMORYLAKE_SEARCH_THRESHOLD=""                   # Min similarity threshold (0~1); omit for server default
MEMORYLAKE_SEARCH_RERANK="false"                   # Rerank is slow (>60s timeout on server); disabled for now

# Rate limiting (official: 60 RPM/IP, 600 RPM/account)
MEMORYLAKE_QPS="1"                                 # Client-side token bucket (1 QPS ≈ 60 RPM)
MEMORYLAKE_TIMEOUT="120"                           # HTTP request timeout seconds (add operations)
MEMORYLAKE_SEARCH_TIMEOUT="20"                     # Search-specific timeout (typical: 1-2s)
MEMORYLAKE_SEARCH_MAX_RETRIES="3"                  # Max search retries (return empty on timeout instead of infinite retry)

# ─── ANSWER (Answer Generation) ─────────────────────────────
ANSWER_MODEL="gpt-4.1-mini"
ANSWER_BASE_URL="https://api.openai.com/v1"        # ⚠️ REQUIRED — set your LLM endpoint
ANSWER_API_KEY="<YOUR_ANSWER_API_KEY>"             # ⚠️ REQUIRED

# ─── EVAL (LLM-as-Judge Scoring) ────────────────────────────
EVAL_MODEL="gpt-4o-mini"
EVAL_BASE_URL="https://api.openai.com/v1"          # ⚠️ REQUIRED — set your LLM endpoint
EVAL_API_KEY="<YOUR_EVAL_API_KEY>"                 # ⚠️ REQUIRED

# ─── Optional Shared Controls ───────────────────────────────
# Memory API retry controls. HTTP retry count includes the initial attempt.
# MEMEVAL_MEMORY_MAX_RETRIES=8
# MEMEVAL_MEMORY_SDK_MAX_RETRIES=8

# Long add-call progress logging. Set to 0 to disable periodic heartbeat logs.
# MEMEVAL_ADD_HEARTBEAT_SECONDS=30

# Global LLM retry/timeout controls. ANSWER_* and EVAL_* override LLM_*.
# LLM_MAX_RETRIES=4
# LLM_TIMEOUT_SECONDS=600
# LLM_RETRY_BASE_SECONDS=1
# LLM_RETRY_MAX_SECONDS=60
# ANSWER_MAX_RETRIES=4
# ANSWER_TIMEOUT_SECONDS=600
# ANSWER_RETRY_BASE_SECONDS=1
# ANSWER_RETRY_MAX_SECONDS=60
# EVAL_MAX_RETRIES=4
# EVAL_TIMEOUT_SECONDS=600
# EVAL_RETRY_BASE_SECONDS=1
# EVAL_RETRY_MAX_SECONDS=60

# Optional metric resource download/cache overrides.
# HF_ENDPOINT="https://huggingface.co"
# HF_HOME="~/.cache/huggingface"
# MEMEVAL_NLTK_INDEX_URL=
# MEMEVAL_NLTK_GITHUB_PROXY=

# Optional global add batching fallback; product-specific *_MAX_BATCH_CHARS wins.
# MAX_BATCH_CHARS=0

# ─── Notification (Optional) ────────────────────────────────
# DINGTALK_ACCESS_TOKEN="<YOUR_DINGTALK_ACCESS_TOKEN>"
# DINGTALK_SECRET="<YOUR_DINGTALK_SECRET>"

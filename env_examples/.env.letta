# ============================================================
# MemEval — Letta (MemGPT)
# Usage: ./scripts/run_locomo_eval.sh --lib letta --env .env.letta
# Docs: https://docs.letta.com/api/
# ============================================================

# ─── Letta API ───────────────────────────────────────────────
LETTA_API_KEY="<YOUR_LETTA_API_KEY>"               # ⚠️ REQUIRED
LETTA_BASE_URL="https://api.letta.com"
LETTA_QPS=2

# ─── Agent model configuration ──────────────────────────────
# Leave unset to use Letta server defaults.
# Options: openai/gpt-4o-mini, openai/gpt-4.1, anthropic/claude-sonnet-4-5-20250929
LETTA_MODEL="openai/gpt-4.1"
LETTA_EMBEDDING_MODEL="openai/text-embedding-3-small"

# Agent type: memgpt_agent | letta_v1_agent | sleeptime_agent | react_agent
# Leave unset for Letta server default
#LETTA_AGENT_TYPE=

# ─── Ingest mode ─────────────────────────────────────────────
# files    : Upload session files to folder → auto chunk/embed (recommended, matches official LoCoMo filesystem)
# archival : Direct insert into archival memory (fastest, deterministic, good for benchmarks)
# messages : Send messages to agent, agent decides what to memorize (slowest, LLM-driven)
LETTA_INGEST_MODE=archival

# ─── Eval mode ───────────────────────────────────────────────
# direct : Agent searches + answers autonomously (matches Letta agent/filesystem eval)
# rag    : Retrieve passages → external ANSWER LLM answers (fair comparison with other products)
LETTA_EVAL_MODE=rag

# ─── Search backend (rag mode only) ─────────────────────────
# passages : POST /v1/passages/search (global search with relevance scores)
# archival : GET /v1/agents/{id}/archival-memory/search (agent-level, supports time filtering)
LETTA_SEARCH_BACKEND=passages

# ─── Sleeptime (background memory consolidation) ────────────
# Enables primary + sleeptime dual-agent architecture
#LETTA_ENABLE_SLEEPTIME=true
# Trigger frequency: every N steps (default 5, recommended 5-10)
#LETTA_SLEEPTIME_AGENT_FREQUENCY=5

# ─── Memory blocks (in-context memory) ──────────────────────
# JSON array, each element {"label": "...", "value": "..."}
# Recommended only when enable_sleeptime=true
#LETTA_MEMORY_BLOCKS_JSON=[{"label":"human","value":""},{"label":"persona","value":"You are a helpful assistant with excellent memory."}]

# ─── Agent creation parameters (leave unset for Letta defaults) ───
#LETTA_AGENT_DESCRIPTION=
#LETTA_SYSTEM=
#LETTA_CONTEXT_WINDOW_LIMIT=
#LETTA_TIMEZONE=
#LETTA_MESSAGE_BUFFER_AUTOCLEAR=
#LETTA_INCLUDE_BASE_TOOLS=
#LETTA_INCLUDE_BASE_TOOL_RULES=
#LETTA_MAX_FILES_OPEN=
#LETTA_PER_FILE_VIEW_WINDOW_CHAR_LIMIT=
#LETTA_MODEL_SETTINGS_JSON=
#LETTA_COMPACTION_SETTINGS_JSON=
#LETTA_INITIAL_MESSAGE_SEQUENCE_JSON=
#LETTA_TOOL_IDS=
#LETTA_TOOLS=
#LETTA_TOOL_RULES_JSON=[{"tool_name":"search_files","type":"run_first"}]
#LETTA_SECRETS_JSON=
#LETTA_IDENTITY_IDS=
#LETTA_FOLDER_IDS=
#LETTA_TAGS=
#LETTA_AGENT_METADATA_JSON=

# ─── Archival memory chunking ─────────────────────────────────
LETTA_BATCH_SIZE=20
# Max characters per archival-memory insert (archival mode).
# Texts exceeding this limit are automatically split at natural boundaries.
LETTA_ARCHIVAL_MAX_CHARS=10000

# ─── File upload parameters (files mode) ─────────────────────
# Duplicate handling: skip | error | suffix | replace
# Recommend "replace" for re-runs to avoid duplicates
LETTA_FILE_DUPLICATE_HANDLING=replace
#LETTA_FOLDER_EMBEDDING_MODEL=
#LETTA_FOLDER_EMBEDDING_CONFIG_JSON=
#LETTA_FOLDER_INSTRUCTIONS=
#LETTA_FOLDER_EMBEDDING_CHUNK_SIZE=

# ─── Messages parameters (messages mode + direct answers) ────
LETTA_MESSAGE_TIMEOUT=120
#LETTA_INGEST_MAX_STEPS=
#LETTA_ANSWER_MAX_STEPS=
#LETTA_ENABLE_THINKING=
#LETTA_INCLUDE_RETURN_MESSAGE_TYPES=

# ─── Runner defaults ────────────────────────────────────────
LLM_WORKERS=10

# ─── Search parameters ──────────────────────────────────────
TOPK=20
#LETTA_SEARCH_TAGS=
#LETTA_SEARCH_TAG_MATCH_MODE=

# ─── Answer prompt (direct mode) ────────────────────────────
#LETTA_ANSWER_PROMPT=Answer the following LoCoMo memory question using your available memories and attached files. If files are available, search them before answering. Return only the shortest possible answer, preferably under 5-6 words.\n\nQuestion: {question}

# ─── ANSWER (Answer Generation, rag mode only) ──────────────
ANSWER_MODEL="gpt-4.1-mini"
ANSWER_BASE_URL="https://api.openai.com/v1"        # ⚠️ REQUIRED — set your LLM endpoint
ANSWER_API_KEY="<YOUR_ANSWER_API_KEY>"             # ⚠️ REQUIRED

# ─── EVAL (LLM-as-Judge Scoring) ────────────────────────────
EVAL_MODEL="gpt-4o-mini"
EVAL_BASE_URL="https://api.openai.com/v1"          # ⚠️ REQUIRED — set your LLM endpoint
EVAL_API_KEY="<YOUR_EVAL_API_KEY>"                 # ⚠️ REQUIRED

# ─── Optional Shared Controls ───────────────────────────────
# Memory API retry controls. HTTP retry count includes the initial attempt.
# MEMEVAL_MEMORY_MAX_RETRIES=8
# MEMEVAL_MEMORY_SDK_MAX_RETRIES=8

# Long add-call progress logging. Set to 0 to disable periodic heartbeat logs.
# MEMEVAL_ADD_HEARTBEAT_SECONDS=30

# Global LLM retry/timeout controls. ANSWER_* and EVAL_* override LLM_*.
# LLM_MAX_RETRIES=4
# LLM_TIMEOUT_SECONDS=600
# LLM_RETRY_BASE_SECONDS=1
# LLM_RETRY_MAX_SECONDS=60
# ANSWER_MAX_RETRIES=4
# ANSWER_TIMEOUT_SECONDS=600
# ANSWER_RETRY_BASE_SECONDS=1
# ANSWER_RETRY_MAX_SECONDS=60
# EVAL_MAX_RETRIES=4
# EVAL_TIMEOUT_SECONDS=600
# EVAL_RETRY_BASE_SECONDS=1
# EVAL_RETRY_MAX_SECONDS=60

# Optional metric resource download/cache overrides.
# HF_ENDPOINT="https://huggingface.co"
# HF_HOME="~/.cache/huggingface"
# MEMEVAL_NLTK_INDEX_URL=
# MEMEVAL_NLTK_GITHUB_PROXY=

# Optional global add batching fallback; product-specific *_MAX_BATCH_CHARS wins.
# MAX_BATCH_CHARS=0

# ─── Notification (Optional) ────────────────────────────────
# DINGTALK_ACCESS_TOKEN="<YOUR_DINGTALK_ACCESS_TOKEN>"
# DINGTALK_SECRET="<YOUR_DINGTALK_SECRET>"

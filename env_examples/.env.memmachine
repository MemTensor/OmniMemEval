# ============================================================
# OmniMemEval — MemMachine (MemVerge)
# Usage: ./scripts/run_locomo_eval.sh --lib memmachine --env .env.memmachine
# Docs: https://docs.memmachine.ai/
# ============================================================

# ─── MemMachine API ──────────────────────────────────────────
# Mode: "cloud" uses api.memmachine.ai; "local" defaults to localhost:8080.
MEMMACHINE_MODE="cloud"
MEMMACHINE_API_KEY="<YOUR_MEMMACHINE_API_KEY>"     # Required for cloud; optional for local
# Leave unset to use the mode default:
#   cloud -> https://api.memmachine.ai
#   local -> http://localhost:8080
# MEMMACHINE_BASE_URL="https://api.memmachine.ai"
MEMMACHINE_BATCH_SIZE=20
MEMMACHINE_MAX_BATCH_CHARS=40000
# Organization ID (default: universal)
MEMMACHINE_ORG_ID="universal"
# Project ID (default: universal)
MEMMACHINE_PROJECT_ID="universal"

# Memory types: episodic (event memory) + semantic (profile memory)
MEMMACHINE_TYPES="episodic,semantic"
# Agent mode: LLM-orchestrated multi-hop retrieval (significant improvement on LoCoMo)
MEMMACHINE_AGENT_MODE="true"
# Context expansion window (contextualized retrieval, +4.2% improvement, recommended: 3)
MEMMACHINE_EXPAND_CONTEXT="3"
# Minimum score threshold (empty = no filter; ignored when agent_mode=true)
MEMMACHINE_SCORE_THRESHOLD=""
# MEMMACHINE_QPS=""

# Lower-cost local single-user benchmark preset:
#   MEMMACHINE_MODE="local"
#   MEMMACHINE_TYPES="episodic"
#   MEMMACHINE_AGENT_MODE="false"

# Runner defaults
LLM_WORKERS=10

# Search parameters
TOPK=20

# ─── ANSWER (Answer Generation) ─────────────────────────────
ANSWER_MODEL="gpt-4.1-mini"
ANSWER_BASE_URL="https://api.openai.com/v1"        # ⚠️ REQUIRED — set your LLM endpoint
ANSWER_API_KEY="<YOUR_ANSWER_API_KEY>"             # ⚠️ REQUIRED

# ─── EVAL (LLM-as-Judge Scoring) ────────────────────────────
EVAL_MODEL="gpt-4o-mini"
EVAL_BASE_URL="https://api.openai.com/v1"          # ⚠️ REQUIRED — set your LLM endpoint
EVAL_API_KEY="<YOUR_EVAL_API_KEY>"                 # ⚠️ REQUIRED

# ─── Optional Shared Controls ───────────────────────────────
# Memory API retry controls. HTTP retry count includes the initial attempt.
# OMNIMEMEVAL_MEMORY_MAX_RETRIES=8
# OMNIMEMEVAL_MEMORY_SDK_MAX_RETRIES=8

# Long add-call progress logging. Set to 0 to disable periodic heartbeat logs.
# OMNIMEMEVAL_ADD_HEARTBEAT_SECONDS=30

# Global LLM retry/timeout controls. ANSWER_* and EVAL_* override LLM_*.
# LLM_MAX_RETRIES=4
# LLM_TIMEOUT_SECONDS=600
# LLM_RETRY_BASE_SECONDS=1
# LLM_RETRY_MAX_SECONDS=60
# ANSWER_MAX_RETRIES=4
# ANSWER_TIMEOUT_SECONDS=600
# ANSWER_RETRY_BASE_SECONDS=1
# ANSWER_RETRY_MAX_SECONDS=60
# EVAL_MAX_RETRIES=4
# EVAL_TIMEOUT_SECONDS=600
# EVAL_RETRY_BASE_SECONDS=1
# EVAL_RETRY_MAX_SECONDS=60

# Optional metric resource download/cache overrides.
# HF_ENDPOINT="https://huggingface.co"
# HF_HOME="~/.cache/huggingface"
# OMNIMEMEVAL_NLTK_INDEX_URL=
# OMNIMEMEVAL_NLTK_GITHUB_PROXY=

# Optional global add batching fallback; product-specific *_MAX_BATCH_CHARS wins.
# MAX_BATCH_CHARS=0

# ─── Notification (Optional) ────────────────────────────────
# DINGTALK_ACCESS_TOKEN="<YOUR_DINGTALK_ACCESS_TOKEN>"
# DINGTALK_SECRET="<YOUR_DINGTALK_SECRET>"

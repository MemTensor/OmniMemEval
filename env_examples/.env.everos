# ============================================================
# OmniMemEval — EverOS (everos)
# Usage: ./scripts/run_locomo_eval.sh --lib everos --env .env.everos
# ============================================================

# ─── EverOS API ──────────────────────────────────────────────
# Mode: "cloud" uses evermind.ai and requires API key; "local" defaults to localhost:1995
EVEROS_MODE="cloud"
EVEROS_API_KEY="<YOUR_EVEROS_API_KEY>"             # Required for cloud; optional for local
# Leave unset to use the mode default:
#   cloud -> https://api.evermind.ai
#   local -> http://localhost:1995
# EVEROS_BASE_URL="https://api.evermind.ai"
EVEROS_QPS=5
EVEROS_TIMEOUT=300
EVEROS_BATCH_SIZE=20
EVEROS_MAX_BATCH_CHARS=40000

# Group memory mode:
#   true  — use /api/v1/memories/group (multi-party conversations, e.g. LoCoMo)
#   false — use /api/v1/memories (single-user conversations, e.g. LongMemEval)
EVEROS_USE_GROUP=true

# Runner defaults
LLM_WORKERS=10

# Search parameters
TOPK=20
# Search method: keyword | vector | hybrid | agentic
# Official LoCoMo eval uses agentic (LLM-guided multi-round retrieval)
EVEROS_SEARCH_METHOD=agentic
# Memory types to search (comma-separated): episodic_memory, profile, raw_message
EVEROS_MEMORY_TYPES=episodic_memory,profile
# Force flush after add to ensure extraction completes before search
EVEROS_FLUSH_AFTER_ADD=true
# Flush policy:
#   always      — safest; flush after every add (default, slowest)
#   accumulated — flush only when add returns "accumulated" (fewer flush calls)
#   never       — fastest; rely on add-time boundary extraction only
EVEROS_FLUSH_POLICY=always
# Request async add processing if the target EverOS deployment supports it.
EVEROS_ASYNC_MODE=false
# LongMemEval-only optimization: use one EverOS session per LME user and flush
# once after all sessions for that user. This reduces flush calls from ~23.9K
# to 500, but changes EverOS's internal session grouping.
EVEROS_LME_FLUSH_ONCE=false
# Fetch profile via /get and merge into search results
EVEROS_FETCH_PROFILE=true

# LongMemEval local preset used for recent local evaluation:
#   EVEROS_MODE=local
#   EVEROS_USE_GROUP=false
#   EVEROS_SEARCH_METHOD=hybrid
#   EVEROS_MEMORY_TYPES=episodic_memory,profile
#   EVEROS_FLUSH_POLICY=always
#   EVEROS_ASYNC_MODE=false
#   EVEROS_LME_FLUSH_ONCE=true

# ─── ANSWER (Answer Generation) ─────────────────────────────
ANSWER_MODEL="gpt-4.1-mini"
ANSWER_BASE_URL="https://api.openai.com/v1"        # ⚠️ REQUIRED — set your LLM endpoint
ANSWER_API_KEY="<YOUR_ANSWER_API_KEY>"             # ⚠️ REQUIRED

# ─── EVAL (LLM-as-Judge Scoring) ────────────────────────────
EVAL_MODEL="gpt-4o-mini"
EVAL_BASE_URL="https://api.openai.com/v1"          # ⚠️ REQUIRED — set your LLM endpoint
EVAL_API_KEY="<YOUR_EVAL_API_KEY>"                 # ⚠️ REQUIRED

# ─── Optional Shared Controls ───────────────────────────────
# Memory API retry controls. HTTP retry count includes the initial attempt.
# OMNIMEMEVAL_MEMORY_MAX_RETRIES=8
# OMNIMEMEVAL_MEMORY_SDK_MAX_RETRIES=8

# Long add-call progress logging. Set to 0 to disable periodic heartbeat logs.
# OMNIMEMEVAL_ADD_HEARTBEAT_SECONDS=30

# Global LLM retry/timeout controls. ANSWER_* and EVAL_* override LLM_*.
# LLM_MAX_RETRIES=4
# LLM_TIMEOUT_SECONDS=600
# LLM_RETRY_BASE_SECONDS=1
# LLM_RETRY_MAX_SECONDS=60
# ANSWER_MAX_RETRIES=4
# ANSWER_TIMEOUT_SECONDS=600
# ANSWER_RETRY_BASE_SECONDS=1
# ANSWER_RETRY_MAX_SECONDS=60
# EVAL_MAX_RETRIES=4
# EVAL_TIMEOUT_SECONDS=600
# EVAL_RETRY_BASE_SECONDS=1
# EVAL_RETRY_MAX_SECONDS=60

# Optional metric resource download/cache overrides.
# HF_ENDPOINT="https://huggingface.co"
# HF_HOME="~/.cache/huggingface"
# OMNIMEMEVAL_NLTK_INDEX_URL=
# OMNIMEMEVAL_NLTK_GITHUB_PROXY=

# Optional global add batching fallback; product-specific *_MAX_BATCH_CHARS wins.
# MAX_BATCH_CHARS=0

# ─── Notification (Optional) ────────────────────────────────
# DINGTALK_ACCESS_TOKEN="<YOUR_DINGTALK_ACCESS_TOKEN>"
# DINGTALK_SECRET="<YOUR_DINGTALK_SECRET>"
